{
  "name": "@philiprehberger/typed-router",
  "version": "0.1.7",
  "description": "Framework-agnostic typed URL routing with path parameter extraction",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "router",
    "routing",
    "typed",
    "url",
    "framework-agnostic",
    "path"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-typed-router.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-typed-router#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-typed-router/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
